#!/usr/bin/env bash

set -u

failed=0

printf '%s\n' 'X11 setup check'
printf '%s\n' '---------------'

if [[ -n "${DISPLAY:-}" ]]; then
    printf 'OK: DISPLAY=%s\n' "$DISPLAY"
else
    printf '%s\n' 'FAIL: DISPLAY is not set.'
    failed=1
fi

if [[ -d /tmp/.X11-unix ]]; then
    printf '%s\n' 'OK: /tmp/.X11-unix exists.'
else
    printf '%s\n' 'WARN: /tmp/.X11-unix is absent (normal for some remote/macOS setups).'
fi

if command -v xauth >/dev/null 2>&1; then
    if [[ -n "${DISPLAY:-}" ]] && xauth nlist "$DISPLAY" 2>/dev/null | grep -q .; then
        printf '%s\n' 'OK: an X11 authorization cookie is available.'
    else
        printf '%s\n' 'WARN: no X11 authorization cookie was found; gui-simple may be needed.'
    fi
else
    printf '%s\n' 'WARN: xauth is not installed; gui-simple may still work.'
fi

if command -v xdpyinfo >/dev/null 2>&1; then
    if xdpyinfo >/dev/null 2>&1; then
        printf '%s\n' 'OK: the host can connect to the X11 display.'
    else
        printf '%s\n' 'FAIL: the host cannot connect to the X11 display.'
        failed=1
    fi
else
    printf '%s\n' 'WARN: xdpyinfo is unavailable, so the display connection was not tested.'
fi

runtime=''
if command -v docker >/dev/null 2>&1; then
    runtime='docker'
elif command -v podman >/dev/null 2>&1; then
    runtime='podman'
fi

if [[ -n "$runtime" ]]; then
    printf 'OK: found container runtime: %s\n' "$runtime"
else
    printf '%s\n' 'FAIL: neither Docker nor Podman was found.'
    failed=1
fi

printf '\nUse "make gui" first; if authentication fails, use "make gui-simple".\n'
exit "$failed"
